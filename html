<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Dashboard Ops</title>
    <style>
        :root {
            --bg-color: #0d1117; /* Fondo oscuro estilo terminal/editor de código */
            --header-bg: #161b22;
            --border-color: #30363d;
            --msg-sent: #1f6feb; /* Azul apagado para tus mensajes */
            --msg-received: #21262d; /* Gris oscuro para los de ella */
            --text-main: #c9d1d9;
            --text-muted: #8b949e;
        }
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
        }
        body {
            background-color: var(--bg-color);
            color: var(--text-main);
            display: flex;
            justify-content: center;
            height: 100vh;
        }
        .chat-container {
            width: 100%;
            max-width: 600px;
            height: 100%;
            display: flex;
            flex-direction: column;
            background-color: var(--bg-color);
            border-left: 1px solid var(--border-color);
            border-right: 1px solid var(--border-color);
        }
        .header {
            background-color: var(--header-bg);
            border-bottom: 1px solid var(--border-color);
            padding: 12px 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: 0.9rem;
            font-weight: 600;
            color: var(--text-muted);
            letter-spacing: 0.5px;
        }
        .user-selector {
            background: var(--bg-color);
            color: var(--text-main);
            border: 1px solid var(--border-color);
            padding: 4px 8px;
            border-radius: 4px;
            outline: none;
            font-size: 0.85rem;
        }
        .chat-box {
            flex: 1;
            padding: 20px;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
            gap: 8px;
        }
        .message {
            max-width: 85%;
            padding: 8px 12px;
            border-radius: 4px; /* Bordes cuadrados, menos aspecto de "chat" */
            position: relative;
            word-wrap: break-word;
            font-size: 0.95rem;
            line-height: 1.4;
        }
        .message.sent {
            align-self: flex-end;
            background-color: var(--msg-sent);
            color: #ffffff;
        }
        .message.received {
            align-self: flex-start;
            background-color: var(--msg-received);
            border: 1px solid var(--border-color);
        }
        .msg-sender {
            font-size: 0.7rem;
            font-weight: 600;
            color: var(--text-muted);
            margin-bottom: 4px;
            display: block;
            text-transform: uppercase;
        }
        .message.sent .msg-sender {
            color: #a5d6ff;
        }
        .msg-time {
            font-size: 0.65rem;
            opacity: 0.7;
            text-align: right;
            margin-top: 4px;
            display: block;
        }
        .input-area {
            background: var(--header-bg);
            border-top: 1px solid var(--border-color);
            padding: 15px;
            display: flex;
            gap: 10px;
            align-items: center;
        }
        .input-area input {
            flex: 1;
            padding: 10px 15px;
            background-color: var(--bg-color);
            color: var(--text-main);
            border: 1px solid var(--border-color);
            border-radius: 4px;
            outline: none;
            font-size: 0.95rem;
        }
        .input-area input:focus {
            border-color: #58a6ff;
        }
        .input-area button {
            background-color: transparent;
            color: var(--text-muted);
            border: 1px solid var(--border-color);
            width: 40px;
            height: 40px;
            border-radius: 4px;
            cursor: pointer;
            display: flex;
            justify-content: center;
            align-items: center;
            transition: all 0.2s;
        }
        .input-area button:hover {
            background-color: var(--border-color);
            color: var(--text-main);
        }
        .input-area button svg {
            width: 18px;
            height: 18px;
            fill: currentColor;
        }
        /* Ocultar barra de desplazamiento para más sigilo */
        ::-webkit-scrollbar {
            width: 6px;
        }
        ::-webkit-scrollbar-track {
            background: var(--bg-color); 
        }
        ::-webkit-scrollbar-thumb {
            background: var(--border-color); 
            border-radius: 3px;
        }
    </style>
</head>
<body>

<div class="chat-container">
    <div class="header">
        <div>System Log_</div>
        <select id="currentUser" class="user-selector">
            <option value="Rodrigo">Rodrigo</option>
            <option value="Noelia">Noelia</option>
        </select>
    </div>

    <div class="chat-box" id="chatBox">
        </div>

    <div class="input-area">
        <input type="text" id="messageInput" placeholder=">_ Ingresar comando..." autocomplete="off" onkeypress="handleKeyPress(event)">
        <button onclick="sendMessage()" title="Ejecutar">
            <svg viewBox="0 0 24 24"><path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"></path></svg>
        </button>
    </div>
</div>

<script>
    const API_URL = 'https://script.google.com/macros/s/AKfycbx_b9hF8hmRrR4_DWM475GL8Gfd1sQS_44Tyz8LPBVrjnfMP1NuKudkZ57s_XX6Cqry/exec'; 
    
    const chatBox = document.getElementById('chatBox');
    const messageInput = document.getElementById('messageInput');
    const currentUserSelect = document.getElementById('currentUser');

    let lastMessageCount = 0;

    async function loadMessages() {
        try {
            const response = await fetch(API_URL);
            const messages = await response.json();

            if (messages.length !== lastMessageCount) {
                chatBox.innerHTML = '';
                const currentUser = currentUserSelect.value;

                messages.forEach(msg => {
                    const isSentByMe = msg.sender === currentUser;
                    const msgDiv = document.createElement('div');
                    msgDiv.className = `message ${isSentByMe ? 'sent' : 'received'}`;
                    
                    msgDiv.innerHTML = `
                        ${!isSentByMe ? `<span class="msg-sender">${msg.sender}</span>` : ''}
                        <span>${msg.text}</span>
                        <span class="msg-time">${msg.timestamp}</span>
                    `;
                    chatBox.appendChild(msgDiv);
                });

                chatBox.scrollTop = chatBox.scrollHeight;
                lastMessageCount = messages.length;
            }
        } catch (error) {
            console.error('Error cargando mensajes:', error);
        }
    }

    async function sendMessage() {
        const text = messageInput.value.trim();
        if (!text) return;

        const sender = currentUserSelect.value;
        messageInput.value = '';

        const msgDiv = document.createElement('div');
        msgDiv.className = `message sent`;
        msgDiv.innerHTML = `<span>${text}</span><span class="msg-time">Procesando...</span>`;
        chatBox.appendChild(msgDiv);
        chatBox.scrollTop = chatBox.scrollHeight;

        try {
            const params = new URLSearchParams();
            params.append('sender', sender);
            params.append('text', text);

            await fetch(API_URL, {
                method: 'POST',
                body: params
            });
            
            loadMessages();
        } catch (error) {
            console.error('Error enviando mensaje:', error);
            msgDiv.querySelector('.msg-time').innerText = 'Error de conexión';
            msgDiv.querySelector('.msg-time').style.color = '#ff7b72';
        }
    }

    function handleKeyPress(event) {
        if (event.key === 'Enter') {
            sendMessage();
        }
    }

    setInterval(loadMessages, 3000);
    loadMessages();

    currentUserSelect.addEventListener('change', () => {
        lastMessageCount = 0; 
        loadMessages();
    });
</script>

</body>
</html>
